generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum SourceHealth {
  HEALTHY
  COOLDOWN
  HALF_OPEN
}

enum JobStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
  RETRYING
}

enum EmbeddingStatus {
  PENDING
  GENERATED
  FAILED
}

model Source {
  id       String       @id @default(uuid())
  name     String       @unique // pubmed, arxiv, semanticscholar
  health   SourceHealth @default(HEALTHY)
  cooldown DateTime?
  papers   Paper[]
}

model ScrapeJob {
  id         String    @id
  status     JobStatus @default(PENDING)
  retries    Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  workerId   String?
}

model Paper {
  id              String          @id @default(uuid())
  title           String
  normalizedTitle String?
  abstract        String?
  doi             String?         @unique
  url             String          @unique
  year            Int?
  sourceId        String
  source          Source          @relation(fields: [sourceId], references: [id])

  // 768 dimensions for nomic-embed-text
  embedding        Unsupported("vector(768)")?
  embeddingStatus  EmbeddingStatus @default(PENDING)

  pdfUrl           String?
  content          PaperContent?

  // Provenance & Diagnostics
  scrapedAt        DateTime?
  extractorVersion String?
  originatingQuery String?
  embeddingModel   String?
  pipelineVersion  String?
  metadata         Json?

  authors          PaperAuthor[]
  extraction       PaperExtraction?
  
  researchTasks    PaperResearchTask[]
  modalities       PaperModality[]
  conditions       PaperCondition[]
  datasets         PaperDataset[]
  methods          PaperMethod[]
  metrics          PaperMetric[]

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([year])
  @@index([sourceId])
  @@index([createdAt])
  @@index([normalizedTitle])
}

model Author {
  id     String        @id @default(uuid())
  name   String        @unique
  papers PaperAuthor[]
}

model PaperAuthor {
  paperId  String
  authorId String
  paper    Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([paperId, authorId])
}

model PaperContent {
  id          String   @id @default(uuid())
  paperId     String   @unique
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  fullText    String
  extractedAt DateTime @default(now())
}

// --- PHASE 2: STRUCTURED KNOWLEDGE EXTRACTION ---

model ResearchTask {
  id       String              @id @default(uuid())
  name     String              @unique
  papers   PaperResearchTask[]
}

model Modality {
  id       String          @id @default(uuid())
  name     String          @unique
  papers   PaperModality[]
}

model Condition {
  id       String           @id @default(uuid())
  name     String           @unique
  papers   PaperCondition[]
}

model Dataset {
  id       String         @id @default(uuid())
  name     String         @unique
  papers   PaperDataset[]
}

model Method {
  id       String        @id @default(uuid())
  name     String        @unique
  papers   PaperMethod[]
}

model Metric {
  id       String        @id @default(uuid())
  name     String        @unique
  papers   PaperMetric[]
}

// Extracted unstructured or semi-structured fields that aren't global concepts
model PaperExtraction {
  id           String   @id @default(uuid())
  paperId      String   @unique
  paper        Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  limitations  String?
  futureWork   String?
  extractedAt  DateTime @default(now())
}

// Join Tables

model PaperResearchTask {
  paperId  String
  taskId   String
  paper    Paper        @relation(fields: [paperId], references: [id], onDelete: Cascade)
  task     ResearchTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  @@id([paperId, taskId])
}

model PaperModality {
  paperId    String
  modalityId String
  paper      Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
  modality   Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)
  @@id([paperId, modalityId])
}

model PaperCondition {
  paperId     String
  conditionId String
  paper       Paper     @relation(fields: [paperId], references: [id], onDelete: Cascade)
  condition   Condition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  @@id([paperId, conditionId])
}

model PaperDataset {
  paperId   String
  datasetId String
  paper     Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)
  dataset   Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  @@id([paperId, datasetId])
}

model PaperMethod {
  paperId  String
  methodId String
  paper    Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  method   Method @relation(fields: [methodId], references: [id], onDelete: Cascade)
  @@id([paperId, methodId])
}

model PaperMetric {
  paperId  String
  metricId String
  paper    Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  metric   Metric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  @@id([paperId, metricId])
}
